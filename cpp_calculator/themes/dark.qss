QWidget { background-color: #12141a; color: #e5e7eb; font-family: 'Inter', 'Segoe UI'; }
QPushButton { background: #232835; border-radius: 12px; padding: 10px; }
QPushButton:hover { background: #2e3648; }
QLineEdit, QTextEdit { background: #1b1f2a; border: 1px solid #2e3648; border-radius: 10px; padding: 8px; }
QListWidget { background: #151925; border: none; }
